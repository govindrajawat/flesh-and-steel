			shape: "square"
			size: 1.5d
			description: [
				"System booting..."
				"Memory corrupted..."
				""
				"You wake up in a world that smells of cold iron and rotting meat. Your skin feels tight, almost plastic. You aren't entirely human anymore, but you aren't a machine either."
			]
			id: "0A1"
			tasks: [{
				id: "0A2"
				type: "checkmark"
				title: "Wake Up"
			}]
